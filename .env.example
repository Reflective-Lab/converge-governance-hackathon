# Kong AI Gateway (required for LLM and external service access)
KONG_AI_GATEWAY_URL=https://<provided-at-hackathon>
KONG_API_KEY=<your-team-key>

# LLM routing (optional, defaults shown)
KONG_LLM_ROUTE=default
KONG_LLM_UPSTREAM_PROVIDER=openai
KONG_LLM_UPSTREAM_MODEL=gpt-4
KONG_LLM_REASONING=true

# Server
PORT=8080
RUST_LOG=info

# Optional: direct provider keys (prefer Kong routing instead)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
