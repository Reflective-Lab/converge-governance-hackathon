# ── Kong AI Gateway (primary LLM routing) ──
KONG_AI_GATEWAY_URL=https://<provided-at-hackathon>
KONG_API_KEY=<your-team-key>
KONG_LLM_ROUTE=default
KONG_LLM_UPSTREAM_PROVIDER=openai
KONG_LLM_UPSTREAM_MODEL=gpt-4
KONG_LLM_REASONING=true

# ── Converge overrides (optional, bypass Kong) ──
# CONVERGE_LLM_FORCE_PROVIDER=anthropic
# CONVERGE_LLM_MODEL=claude-sonnet-4-20250514

# ── LLM provider keys ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# ── Search & tools ──
BRAVE_API_KEY=
TAVILY_API_KEY=
PERPLEXITY_API_KEY=

# ── Server ──
GOVERNANCE_ADDR=127.0.0.1:8080
RUST_LOG=info
